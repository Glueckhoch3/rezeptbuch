# rezeptbuch environment configuration
# Copy this file to ".env" and adjust values for your local setup.
# ".env" is git-ignored and must never contain real secrets in version control.

# --- PostgreSQL database ---
POSTGRES_USER=rezeptbuch
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=rezeptbuch
# Host/port as seen by the backend. Inside Docker the host is the service name "db".
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Port exposed on the host machine for direct DB access (optional).
POSTGRES_HOST_PORT=5432

# --- Backend (Flask) ---
# Secret key used by Flask for signing; set a long random value outside dev.
BACKEND_SECRET_KEY=change-me-locally
# Comma-separated list of browser origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
# Number of gunicorn workers in the container.
GUNICORN_WORKERS=2
# Set to "true" to insert example recipes on first container start.
SEED_ON_START=false

# --- Frontend ---
# Port the frontend (nginx) is published on the host machine.
FRONTEND_HOST_PORT=8080
# Backend target used by the Vite dev server proxy during local development.
VITE_API_PROXY_TARGET=http://localhost:5000
